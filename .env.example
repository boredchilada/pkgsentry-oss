# pkgsentry — example environment configuration
#
# Copy to .env and fill in values. .env is gitignored.

# === Required ===

# OpenRouter API key for LLM triage (optional but recommended).
# Without this, scans still complete via static rules; LLM triage is skipped.
OPENROUTER_API_KEY=

# Discord webhook for malicious-package alerts (optional).
# Without this, malicious findings still persist to the DB; no alerts are sent.
DISCORD_WEBHOOK_URL=

# === Database ===

# Connection URL. Default is local SQLite (WAL mode) — fine for development.
# For production: postgresql://<user>:<password>@<host>:<port>/<db>
# Note: docker-compose.standalone.yml overrides this automatically — no edit needed.
PKGSENTRY_DB_URL=sqlite:///pkgsentry.db

# === Polite-scraper identity ===

# Contact identifier surfaced in the User-Agent on all outbound requests
# to PyPI, crates.io, and the Go module proxy. Set this to a URL or email
# you control so registry maintainers can reach you if your scanner ever
# misbehaves. Defaults to the project URL if unset.
PKGSENTRY_CONTACT_EMAIL=

# === Ingest control ===

# 1 = poll feeds and enqueue new packages. 0 = drain the existing queue only.
SCANNER_INGEST=1

# Focus packages: load with `pkgsentry focus load <file> -e <eco>`.
# 0 = additive (focus packages scanned at high priority plus the normal gates).
# 1 = exclusive (scan ONLY focus-list packages; watchlist + brand-new skipped).
PKGSENTRY_FOCUS_EXCLUSIVE=0

# Set to 1 to scan Go pseudo-versions. Default skips them (high volume,
# usually transient development snapshots).
GOMOD_SCAN_PSEUDO=0

# === LLM triage ===

# Model identifier passed to OpenRouter.
PKGSENTRY_LLM_MODEL=z-ai/glm-5.1

# Per-process budget cap in USD. Hard stop — once reached, triage is
# skipped for the rest of the process lifetime.
PKGSENTRY_LLM_MAX_USD=20.0

# Rate limit. Hard stop on hourly call count.
PKGSENTRY_LLM_MAX_CALLS_PER_HOUR=1000

# === Intel pack overlay ===

# Path to a private intel pack (YARA rules, hash seeds, prompts, thresholds).
# If unset, only the public baseline pack ships with the engine is loaded.
# Operators with their own threat intel should point this at their pack
# directory — see docs/intel-pack.md.
# PKGSENTRY_INTEL_PATH=/path/to/private/intel/pack

# === opengrep static-analysis layer ===

# Master kill switch. 1 = analyzer is wired into the pipeline.
# 0 = analyzer is skipped entirely (legacy regex/AST layers continue normally).
OPENGREP_ENABLED=1

# Shadow mode. 1 (default) = findings emit as `opengrep.shadow_<id>` and are
# EXCLUDED from scoring. The legacy install-time analyzers (PyPI installer.py,
# Crates build_rs.py) continue to run. This is the prod-safe default.
#
# 0 = findings emit as `opengrep.<id>` and contribute to scoring/verdict.
# The legacy install-time analyzers are SKIPPED. Only flip this after the
# soak-period comparison shows opengrep parity (see docs/opengrep-shadow-report.md).
OPENGREP_SHADOW=1

# Per-package wall-clock timeout for the opengrep subprocess. On timeout the
# analyzer returns no findings and logs `opengrep_timeout` — the rest of the
# scan continues normally.
OPENGREP_TIMEOUT_SEC=60

# Binary path / PATH lookup name. Override only for testing.
# OPENGREP_BIN=opengrep

# === Detonation (PyPI dynamic analysis, optional) ===

# Path to the detonation service UNIX socket. Set if you've deployed the
# Go sandbox service (see docs/detonation.md). Leave unset to run engine
# without dynamic analysis.
# DETONATION_SOCKET=/var/run/detonation/detonation.sock

# TCP fallback if you're running the sandbox on a different host.
# DETONATION_URL=http://detonation-host:8080

# === Optional ===

# GitHub API token. Improves rate limits when building the Go modules
# watchlist (by-stars query); not required.
GITHUB_TOKEN=
