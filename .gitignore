# Private intel pack — overlay loaded at runtime via PKGSENTRY_INTEL_PATH.
# The public baseline lives at pkgsentry/intel/baseline/ and IS tracked.
# Leading slash anchors this pattern to the repo root so it does NOT also
# match `pkgsentry/intel/` or `tests/intel/`.
/intel/

# Internal session state
HANDOFF.md

# Stale workspace artifacts
pypi_scanner/
qc.py

# Binary build artifacts (detonation Go service)
*.exe
detonation/detonation-svc
detonation/bin/

# Home-dir dotfiles + harness state — this tree lives in a home dir on the
# prod scanner host (/home/pkgsentry); these are not part of the project.
.bashrc
.bash_profile
.bash_logout
.zshrc
.profile
.claude/
.git.broken-bak
