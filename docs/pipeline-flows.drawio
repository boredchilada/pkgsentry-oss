        <mxCell id="r-boot" value="&lt;b&gt;Boot-time One-shot Ingest&lt;/b&gt;&lt;br&gt;(non-fatal if fails)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="490" y="460" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="er-schb" edge="1" source="r-sched" target="r-boot" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="r-b1" value="1. refresh_watchlist()&lt;br&gt;(if table empty)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="440" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r-b2" value="2. poll_feeds_once()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="490" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r-b3" value="3. pull_since()&lt;br&gt;(in asyncio.to_thread)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="530" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="er-bb1" edge="1" source="r-boot" target="r-b1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er-b12" edge="1" source="r-b1" target="r-b2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er-b23" edge="1" source="r-b2" target="r-b3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Start worker pool -->
        <mxCell id="r-pool" value="&lt;b&gt;Start Worker Pool&lt;/b&gt;&lt;br&gt;run_pool(num_workers, stop_event)&lt;br&gt;N concurrent asyncio tasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="530" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="er-bp" edge="1" source="r-boot" target="r-pool" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Main wait loop -->
        <mxCell id="r-wait" value="&lt;b&gt;Wait for shutdown signal&lt;/b&gt;&lt;br&gt;&lt;br&gt;duration &amp;gt; 0 → asyncio.wait_for(stop, timeout=duration)&lt;br&gt;duration == 0 → await stop_event.wait()&lt;br&gt;KeyboardInterrupt → stop_event.set()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="410" y="620" width="340" height="80" as="geometry" />
        </mxCell>
        <mxCell id="er-pw" edge="1" source="r-pool" target="r-wait" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Shutdown -->
        <mxCell id="r-shut" value="&lt;b&gt;Graceful Shutdown&lt;/b&gt;&lt;br&gt;1. scheduler.shutdown(wait=False)&lt;br&gt;2. await pool_task (workers drain)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="450" y="730" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="er-ws" edge="1" source="r-wait" target="r-shut" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- End -->
        <mxCell id="r-end" value="" style="ellipse;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="570" y="810" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="er-se" edge="1" source="r-shut" target="r-end" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Concurrent note -->
        <mxCell id="r-note" value="&lt;b&gt;Concurrency Model&lt;/b&gt;&lt;br&gt;&lt;br&gt;Single asyncio event loop:&lt;br&gt;• APScheduler fires ingest jobs&lt;br&gt;• N worker tasks poll queue&lt;br&gt;• httpx async for all HTTP I/O&lt;br&gt;• DB sessions are short-lived&lt;br&gt;  (never held across await)&lt;br&gt;&lt;br&gt;SQLite WAL mode allows concurrent&lt;br&gt;reads during writes. busy_timeout=10s." style="text;html=1;fontSize=10;align=left;fillColor=#D4E1F5;strokeColor=#7EA6E0;rounded=1;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="820" y="620" width="250" height="170" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- PAGE 6: Scoring & Verdict -->
  <diagram id="scoring" name="6. Scoring &amp; Verdict">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title6" value="&lt;b&gt;Scoring &amp; Verdict Decision Flow&lt;/b&gt;" style="text;html=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Input -->
        <mxCell id="sc-in" value="&lt;b&gt;Input: list[Finding]&lt;/b&gt;&lt;br&gt;Each has: rule_id, severity,&lt;br&gt;category, confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Point calculation -->
        <mxCell id="sc-points" value="&lt;b&gt;Calculate Points&lt;/b&gt;&lt;br&gt;&lt;br&gt;low = 1 pt&lt;br&gt;medium = 8 pts&lt;br&gt;high = 25 pts&lt;br&gt;critical = 60 pts&lt;br&gt;&lt;br&gt;Per-category cap: 30 pts max&lt;br&gt;(prevents IOC spam from dominating)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="230" height="140" as="geometry" />
        </mxCell>
        <mxCell id="esc1" edge="1" source="sc-in" target="sc-points" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Decision chain -->
        <mxCell id="sc-d1" value="score ≥ 61&lt;br&gt;OR critical finding&lt;br&gt;OR chain rule?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="esc2" edge="1" source="sc-points" target="sc-d1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc-mal" value="&lt;b&gt;MALICIOUS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="110" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="esc3" value="Yes" style="fontSize=10;" edge="1" source="sc-d1" target="sc-mal" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc-d2" value="score ≥ 20&lt;br&gt;OR high finding?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="230" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="esc4" value="No" style="fontSize=10;" edge="1" source="sc-d1" target="sc-d2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc-sus" value="&lt;b&gt;SUSPICIOUS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="240" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="esc5" value="Yes" style="fontSize=10;" edge="1" source="sc-d2" target="sc-sus" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc-clean" value="&lt;b&gt;CLEAN&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="340" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="esc6" value="No" style="fontSize=10;" edge="1" source="sc-d2" target="sc-clean" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Watchlist Escalation -->
        <mxCell id="sc-wl-title" value="&lt;b&gt;Watchlist Escalation&lt;/b&gt;" style="text;html=1;fontSize=14;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="250" height="25" as="geometry" />
        </mxCell>

        <mxCell id="sc-wl1" value="is_watchlist(name)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="sc-wl2" value="Has medium+&lt;br&gt;findings?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="440" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="esc-w1" value="Yes" style="fontSize=10;" edge="1" source="sc-wl1" target="sc-wl2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc-wl-esc1" value="clean → &lt;b&gt;SUSPICIOUS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="450" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="esc-w2" value="Yes" style="fontSize=10;" edge="1" source="sc-wl2" target="sc-wl-esc1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc-wl3" value="Rank ≤ 100 AND&lt;br&gt;high/crit findings?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="540" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="esc-w3" value="Also check" style="fontSize=10;dashed=1;" edge="1" source="sc-wl2" target="sc-wl3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc-wl-esc2" value="→ &lt;b&gt;MALICIOUS&lt;/b&gt;&lt;br&gt;alert_tag=watchlist_top100" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="545" width="200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="esc-w4" value="Yes" style="fontSize=10;" edge="1" source="sc-wl3" target="sc-wl-esc2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- LLM Override -->
        <mxCell id="sc-llm-title" value="&lt;b&gt;LLM Override Rules&lt;/b&gt;" style="text;html=1;fontSize=14;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="250" height="25" as="geometry" />
        </mxCell>

        <mxCell id="sc-llm-box" value="If LLM triage returns a verdict:&lt;br&gt;&lt;br&gt;• LLM verdict &lt;b&gt;overrides&lt;/b&gt; rule verdict on the Scan row&lt;br&gt;• EXCEPT: if rules triggered a behavioral chain rule&lt;br&gt;  (urlopen_exec_chain or network_subprocess_chain)&lt;br&gt;  → verdict stays MALICIOUS regardless of LLM opinion&lt;br&gt;&lt;br&gt;• LLM-reported IOCs are post-validated against source&lt;br&gt;  (hallucinated IOCs are dropped)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="680" width="420" height="120" as="geometry" />
        </mxCell>

        <!-- Chain rules box -->
        <mxCell id="sc-chains" value="&lt;b&gt;Behavioral Chain Rules&lt;/b&gt;&lt;br&gt;(always → MALICIOUS, no override)&lt;br&gt;&lt;br&gt;• installer.urlopen_exec_chain&lt;br&gt;  (setup.py: network → exec)&lt;br&gt;&lt;br&gt;• imports.network_subprocess_chain&lt;br&gt;  (__init__.py: network + subprocess)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="440" width="260" height="130" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
