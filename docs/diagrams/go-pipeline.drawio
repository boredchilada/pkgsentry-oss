  <diagram id="go-pipeline" name="Go Modules Ecosystem Pipeline">
    <mxGraphModel dx="1800" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="4200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== TITLE ===== -->
        <mxCell id="title" value="&lt;b&gt;Go Modules Ecosystem Pipeline&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=20;" vertex="1" parent="1">
          <mxGeometry x="370" y="20" width="520" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== STATUS BANNER ===== -->
        <mxCell id="status_banner" value="&lt;b&gt;Status: ACTIVE in production&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ingest, watchlist, fetch, extract, static analysis, and detonation all run for Go modules.&lt;br&gt;Watchlist (~9K) is built from GitHub stars + awesome-go + critical-infrastructure modules &amp;mdash; no official download API needed.&lt;br&gt;&lt;br&gt;&lt;i&gt;Reference: docs/ecosystems-reference.md (Go modules &amp;mdash; ACTIVE)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#2d5016;fontSize=12;shadow=1;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="70" width="640" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 1 — INGEST ===== -->
        <!-- Phase background -->
        <mxCell id="bg_p1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="200" width="860" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p1_label" value="&lt;b&gt;Phase 1 &amp;mdash; Ingest&lt;/b&gt;  (NDJSON index cursor, every 60s)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#1a3a6b;" vertex="1" parent="1">
          <mxGeometry x="230" y="205" width="400" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="n_ndjson" value="&lt;b&gt;NDJSON index feed&lt;/b&gt;&lt;br&gt;&lt;code&gt;index.golang.org/index?since=&amp;lt;timestamp&amp;gt;&lt;/code&gt;&lt;br&gt;&lt;br&gt;Returns lines of:&lt;br&gt;&lt;code&gt;{&amp;quot;Path&amp;quot;:&amp;quot;...&amp;quot;,&amp;quot;Version&amp;quot;:&amp;quot;...&amp;quot;,&amp;quot;Timestamp&amp;quot;:&amp;quot;...&amp;quot;}&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="430" y="240" width="400" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="n_poll" value="&lt;b&gt;Cursor-based polling&lt;/b&gt;&lt;br&gt;Page with last-seen timestamp, persisted in ScanCursor&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Pseudo-versions skipped (GOMOD_SCAN_PSEUDO=0)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="460" y="350" width="340" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_ndjson_poll" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_ndjson" target="n_poll" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_watchlist_q" value="&lt;b&gt;On watchlist&lt;br&gt;or brand-new?&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;watchlist=high, new=normal&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="480" y="430" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_poll_wq" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_poll" target="n_watchlist_q" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 2 — WATCHLIST ===== -->
        <mxCell id="bg_p2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="570" width="860" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p2_label" value="&lt;b&gt;Phase 2 &amp;mdash; Watchlist&lt;/b&gt;  (~9K modules, weekly refresh)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#2d5016;" vertex="1" parent="1">
          <mxGeometry x="230" y="575" width="400" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="n_problem" value="&lt;b&gt;Watchlist built from three sources&lt;/b&gt; &amp;mdash; combined &amp;amp; ranked&lt;br&gt;by star count; ~9K module paths total" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#2d5016;" vertex="1" parent="1">
          <mxGeometry x="400" y="610" width="460" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="n_src1" value="&lt;b&gt;GitHub stars&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;language:go, bucketed star queries&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="280" y="690" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n_src2" value="&lt;b&gt;awesome-go&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;curated module paths from README&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="540" y="690" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n_src3" value="&lt;b&gt;Critical infrastructure&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;k8s.io, golang.org/x, etc.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="800" y="690" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e_prob_src1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_problem" target="n_src1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_prob_src2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_problem" target="n_src2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_prob_src3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_problem" target="n_src3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_target_size" value="&lt;b&gt;~9K watchlist &amp;rarr; resolve @latest via GOPROXY&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;proxy.golang.org/{module}/@latest, concurrency=20&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="460" y="780" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_src1_target" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_src1" target="n_target_size" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_src2_target" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_src2" target="n_target_size" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_src3_target" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_src3" target="n_target_size" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_wq_to_p2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_watchlist_q" target="n_problem" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 3 — FETCH ===== -->
        <mxCell id="bg_p3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="940" width="860" height="370" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p3_label" value="&lt;b&gt;Phase 3 &amp;mdash; Fetch&lt;/b&gt;  (GOPROXY protocol, async I/O)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#6b5900;" vertex="1" parent="1">
          <mxGeometry x="230" y="945" width="340" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="n_proxy" value="&lt;b&gt;GOPROXY zip download&lt;/b&gt;&lt;br&gt;&lt;code&gt;proxy.golang.org/{module}/@v/{version}.zip&lt;/code&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;case-encoded path (Burnt&amp;rarr;!burnt); 404/410 &amp;rarr; NoFilesError&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="420" y="980" width="420" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_target_proxy" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_target_size" target="n_proxy" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_meta" value="&lt;b&gt;Also fetch:&lt;/b&gt;&lt;br&gt;&lt;code&gt;.info&lt;/code&gt; metadata JSON &amp;rarr; pkg.go.dev home_page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="1050" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_proxy_meta" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_proxy" target="n_meta" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_cache_note" value="&lt;font color=&quot;#6b5900&quot;&gt;&lt;i&gt;Module proxy caches indefinitely &amp;mdash;&lt;br&gt;deleted repos stay cached&lt;/i&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="1050" width="220" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_proxy_cache" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_proxy" target="n_cache_note" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_sumdb" value="&lt;b&gt;SHA256 hash of downloaded zip&lt;/b&gt;&lt;br&gt;recorded on the ArchivePath&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(GOPROXY content already integrity-backed by the module proxy)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="1120" width="460" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_meta_sumdb" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_meta" target="n_sumdb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_paths_note" value="&lt;font color=&quot;#6b5900&quot;&gt;&lt;i&gt;Module paths can be deeply nested:&lt;br&gt;&lt;code&gt;github.com/user/repo/v2/subpkg&lt;/code&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1210" width="250" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_archive_note" value="&lt;b&gt;Single archive:&lt;/b&gt; .zip file" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="1210" width="180" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 4 — EXTRACT + HASH ===== -->
        <mxCell id="bg_p4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="1340" width="860" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p4_label" value="&lt;b&gt;Phase 4 &amp;mdash; Extract + Hash&lt;/b&gt;  (asyncio.to_thread)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#2d5016;" vertex="1" parent="1">
          <mxGeometry x="230" y="1345" width="340" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="n_extract" value="&lt;b&gt;safe_extract()&lt;/b&gt;&lt;br&gt;Same as other ecosystems (strips_top_dir)&lt;br&gt;file cap, size cap, reject symlinks/path traversal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="430" y="1380" width="400" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_sumdb_extract" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_sumdb" target="n_extract" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_hash" value="&lt;b&gt;SHA256 + entropy + ssdeep&lt;/b&gt;&lt;br&gt;per-file hashing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="470" y="1460" width="320" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_extract_hash" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_extract" target="n_hash" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_go_src_note" value="&lt;font color=&quot;#2d5016&quot;&gt;&lt;i&gt;Go modules contain only Go source files&lt;br&gt;(no compiled artifacts normally)&lt;/i&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1470" width="250" height="36" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 5 — INSTALL-TIME ANALYSIS ===== -->
        <mxCell id="bg_p5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="1610" width="860" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p5_label" value="&lt;b&gt;Phase 5 &amp;mdash; Install-time Analysis&lt;/b&gt;  (go_directives.py, regex + brace-matching)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#4a2d6b;" vertex="1" parent="1">
          <mxGeometry x="230" y="1615" width="500" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="n_install_note" value="&lt;b&gt;analyze_go_directives()&lt;/b&gt; &amp;mdash; Go has no setup.py/build.rs;&lt;br&gt;scans .go + go.mod for auto-executing &amp;amp; build-time attack surfaces" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#4a2d6b;" vertex="1" parent="1">
          <mxGeometry x="370" y="1650" width="520" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_hash_install" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_hash" target="n_install_note" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_gogen" value="&lt;b&gt;//go:generate&lt;/b&gt;&lt;br&gt;&lt;code&gt;go_generate_exec&lt;/code&gt; (CRIT) / &lt;code&gt;go_generate&lt;/code&gt; (low)&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;benign-tool whitelist from intel pack&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="250" y="1730" width="240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_init" value="&lt;b&gt;init() body analysis&lt;/b&gt;&lt;br&gt;&lt;code&gt;init_exec_chain&lt;/code&gt; (CRIT), &lt;code&gt;init_net_chain&lt;/code&gt;,&lt;br&gt;&lt;code&gt;init_env_harvest&lt;/code&gt; + coexist fallbacks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="520" y="1730" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n_cgo" value="&lt;b&gt;CGo&lt;/b&gt;&lt;br&gt;&lt;code&gt;import &amp;quot;C&amp;quot;&lt;/code&gt; blocks embed C code&lt;br&gt;&lt;code&gt;cgo_exec_chain&lt;/code&gt; (CRIT) /&lt;br&gt;&lt;code&gt;cgo_import&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="770" y="1730" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n_plugin" value="&lt;b&gt;replace + unsafe + encoded&lt;/b&gt;&lt;br&gt;&lt;code&gt;replace_local_path&lt;/code&gt; / &lt;code&gt;replace_directive&lt;/code&gt; hijack,&lt;br&gt;&lt;code&gt;unsafe_import&lt;/code&gt;, &lt;code&gt;encoded_payload&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="380" y="1830" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e_inst_gogen" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_install_note" target="n_gogen" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_inst_init" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_install_note" target="n_init" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_inst_cgo" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_install_note" target="n_cgo" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_inst_plugin" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_install_note" target="n_plugin" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_rule_design" value="&lt;b&gt;Collect install-time findings&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;13 Go-specific rules, scoped to changed files on version diff&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#4a2d6b;" vertex="1" parent="1">
          <mxGeometry x="430" y="1920" width="400" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_gogen_rule" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_gogen" target="n_rule_design" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_init_rule" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_init" target="n_rule_design" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_cgo_rule" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_cgo" target="n_rule_design" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_plugin_rule" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_plugin" target="n_rule_design" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 6 — UNIVERSAL ANALYSIS ===== -->
        <mxCell id="bg_p6" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="2020" width="860" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p6_label" value="&lt;b&gt;Phase 6 &amp;mdash; Universal Analysis&lt;/b&gt;  (same as PyPI/Crates)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#4a2d6b;" vertex="1" parent="1">
          <mxGeometry x="230" y="2025" width="380" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="n_universal" value="&lt;b&gt;Universal Analyzers&lt;/b&gt; (same as PyPI/Crates)&lt;br&gt;analyze_imports, analyze_iocs, analyze_entropy,&lt;br&gt;analyze_entropy_delta, analyze_binary_artifacts, analyze_yara,&lt;br&gt;version_diff" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="370" y="2060" width="520" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_rule_univ" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_rule_design" target="n_universal" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_yara_note" value="&lt;font color=&quot;#4a2d6b&quot;&gt;&lt;i&gt;May need Go-specific YARA rules&lt;br&gt;for Go source patterns&lt;/i&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="2160" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 7 — DETONATION ===== -->
        <mxCell id="bg_p7" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="2290" width="860" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p7_label" value="&lt;b&gt;Phase 7 &amp;mdash; Detonation enqueue&lt;/b&gt;  (async; drained by detonation_worker)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#6b4e00;" vertex="1" parent="1">
          <mxGeometry x="230" y="2295" width="380" height="24" as="geometry"/>
