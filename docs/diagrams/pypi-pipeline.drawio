          <mxGeometry x="220" y="940" width="860" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p3_label" value="&lt;b&gt;Phase 3 &amp;mdash; Fetch&lt;/b&gt;  (async I/O, rate-limited)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#6b5900;" vertex="1" parent="1">
          <mxGeometry x="230" y="945" width="340" height="24" as="geometry"/>
        </mxCell>

        <!-- Phase 4 - Extract + Hash background -->
        <mxCell id="bg_p4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="1350" width="860" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p4_label" value="&lt;b&gt;Phase 4 &amp;mdash; Extract + Hash&lt;/b&gt;  (asyncio.to_thread)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#2d5016;" vertex="1" parent="1">
          <mxGeometry x="230" y="1355" width="340" height="24" as="geometry"/>
        </mxCell>

        <!-- Phase 5 - Install-time Analysis background -->
        <mxCell id="bg_p5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="1690" width="860" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p5_label" value="&lt;b&gt;Phase 5 &amp;mdash; Install-time Analysis&lt;/b&gt;  (setup.py AST)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#4a2d6b;" vertex="1" parent="1">
          <mxGeometry x="230" y="1695" width="360" height="24" as="geometry"/>
        </mxCell>

        <!-- Phase 6 - Universal Analysis background -->
        <mxCell id="bg_p6" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="2100" width="860" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p6_label" value="&lt;b&gt;Phase 6 &amp;mdash; Universal Analysis&lt;/b&gt;  (asyncio.to_thread)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#4a2d6b;" vertex="1" parent="1">
          <mxGeometry x="230" y="2105" width="360" height="24" as="geometry"/>
        </mxCell>

        <!-- Phase 7 - Detonation background -->
        <mxCell id="bg_p7" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="2560" width="860" height="420" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p7_label" value="&lt;b&gt;Phase 7 &amp;mdash; Detonation&lt;/b&gt;  (PyPI only &amp;mdash; differentiator)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#6b4e00;" vertex="1" parent="1">
          <mxGeometry x="230" y="2565" width="380" height="24" as="geometry"/>
        </mxCell>

        <!-- Phase 8 - LLM Triage + Alert background -->
        <mxCell id="bg_p8" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="220" y="3010" width="860" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p8_label" value="&lt;b&gt;Phase 8 &amp;mdash; LLM Triage + Alert&lt;/b&gt;  (cost-gated)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="230" y="3015" width="340" height="24" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 1 — INGEST ===== -->

        <!-- RSS Feeds -->
        <mxCell id="n_rss_updates" value="&lt;b&gt;RSS: updates.xml&lt;/b&gt;&lt;br&gt;pypi.org/rss/updates.xml&lt;br&gt;Version updates, polled every 60s&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Regex-parsed (not full XML)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="260" y="120" width="250" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_rss_packages" value="&lt;b&gt;RSS: packages.xml&lt;/b&gt;&lt;br&gt;pypi.org/rss/packages.xml&lt;br&gt;New packages, polled every 60s&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Regex-parsed (not full XML)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="250" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_xmlrpc" value="&lt;b&gt;XML-RPC Cursor&lt;/b&gt;&lt;br&gt;pypi.org/pypi &amp;rarr; changelog_since_serial()&lt;br&gt;Polled every 120s, serial persisted in ScanCursor&lt;br&gt;Capped at 2000 entries/pull&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Supports backfill(days)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="840" y="120" width="220" height="100" as="geometry"/>
        </mxCell>

        <!-- Log: serial persisted -->
        <mxCell id="n_log_serial" value="log: &lt;b&gt;cursor_polled&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(serial, entries)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="230" width="160" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="e_xmlrpc_log" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_xmlrpc" target="n_log_serial" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Merge feeds -->
        <mxCell id="n_merge_feeds" value="&lt;b&gt;Merge &amp;amp; deduplicate&lt;/b&gt;&lt;br&gt;(pkg, version) from all three sources" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="480" y="250" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_rss1_merge" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_rss_updates" target="n_merge_feeds" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_rss2_merge" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_rss_packages" target="n_merge_feeds" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_xmlrpc_merge" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_xmlrpc" target="n_merge_feeds" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="950" y="240"/>
              <mxPoint x="760" y="240"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Watchlist gate diamond -->
        <mxCell id="d_watchlist_gate" value="&lt;b&gt;On&lt;br&gt;watchlist?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="565" y="340" width="110" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_merge_gate" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_merge_feeds" target="d_watchlist_gate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Skip (not on watchlist) -->
        <mxCell id="n_skip_ingest" value="&lt;font color=&quot;#888888&quot;&gt;Skip&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="810" y="355" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_gate_no" value="No" style="edgeStyle=orthogonalEdgeStyle;fontColor=#cc0000;" edge="1" source="d_watchlist_gate" target="n_skip_ingest" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Enqueue -->
        <mxCell id="n_enqueue" value="&lt;b&gt;Enqueue scan job&lt;/b&gt;&lt;br&gt;(pkg, version, priority)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="530" y="450" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_gate_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_watchlist_gate" target="n_enqueue" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log enqueue -->
        <mxCell id="n_log_enqueue" value="log: &lt;b&gt;enqueued&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(pkg, version, source)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="455" width="180" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="e_enqueue_log" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_enqueue" target="n_log_enqueue" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 2 — WATCHLIST ===== -->

        <mxCell id="n_wl_source" value="&lt;b&gt;Watchlist source&lt;/b&gt;&lt;br&gt;hugovk.github.io/top-pypi-packages/&lt;br&gt;top-pypi-packages.min.json&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Top 10,000 packages by downloads&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="440" y="600" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_enqueue_wl" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_enqueue" target="n_wl_source" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_wl_refresh" value="&lt;b&gt;Refresh weekly&lt;/b&gt;&lt;br&gt;Wipe-and-reinsert pattern" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="490" y="710" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_refresh" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_wl_source" target="n_wl_refresh" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_wl_seed" value="&lt;b&gt;First boot seed&lt;/b&gt;&lt;br&gt;Empty watchlist &amp;rarr; seed all 10K names&lt;br&gt;Poll pypi.org/pypi/{name}/json for latest version&lt;br&gt;concurrency=20 &amp;rarr; enqueue all high-priority" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="420" y="790" width="360" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_seed" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_wl_refresh" target="n_wl_seed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log watchlist -->
        <mxCell id="n_log_wl" value="log: &lt;b&gt;watchlist_refreshed&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(count, seeded)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="800" width="180" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_wl_seed" target="n_log_wl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 3 — FETCH ===== -->

        <mxCell id="n_fetch_json" value="&lt;b&gt;Fetch PyPI JSON&lt;/b&gt;&lt;br&gt;GET pypi.org/pypi/{name}/{version}/json&lt;br&gt;Extract archive URLs + SHA256 digests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="450" y="980" width="300" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_seed_fetch" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_wl_seed" target="n_fetch_json" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_download" value="&lt;b&gt;Download archives concurrently&lt;/b&gt;&lt;br&gt;sdist (.tar.gz) + wheel (.whl)&lt;br&gt;from files.pythonhosted.org&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Rate limited: 10 req/s | strips_top_dir=True&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Temp dir: %TEMP%/pkgsentry&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="430" y="1080" width="340" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e_json_download" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_fetch_json" target="n_download" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Note: either or both -->
        <mxCell id="n_note_archives" value="&lt;font color=&quot;#888888&quot;&gt;&lt;i&gt;Either or both archives&lt;br&gt;may be absent; at least&lt;br&gt;one required or&lt;br&gt;NoFilesError&lt;/i&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="1085" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_download_note" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_download" target="n_note_archives" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_verify_sha" value="&lt;b&gt;Verify SHA256&lt;/b&gt;&lt;br&gt;post-download against PyPI JSON digests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="460" y="1200" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_download_sha" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_download" target="n_verify_sha" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fetch OK? -->
        <mxCell id="d_fetch_ok" value="&lt;b&gt;Fetch OK?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="555" y="1270" width="110" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_sha_fetchok" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_verify_sha" target="d_fetch_ok" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fetch fail → error -->
        <mxCell id="e_fetchok_fail" value="No" style="edgeStyle=orthogonalEdgeStyle;fontColor=#cc0000;" edge="1" source="d_fetch_ok" target="n_error" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1200" y="1300"/>
              <mxPoint x="1200" y="3870"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Log downloaded -->
        <mxCell id="n_log_downloaded" value="log: &lt;b&gt;downloaded&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(archives, total_mb)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1275" width="180" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="e_fetchok_log" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#CCCCCC;" edge="1" source="d_fetch_ok" target="n_log_downloaded" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 4 — EXTRACT + HASH ===== -->

        <mxCell id="n_extract" value="&lt;b&gt;safe_extract()&lt;/b&gt;&lt;br&gt;For each archive (sdist + wheel)&lt;br&gt;10K file cap, 500MB cap&lt;br&gt;Reject symlinks / path traversal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="450" y="1390" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_fetchok_extract" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_fetch_ok" target="n_extract" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_hash" value="&lt;b&gt;Compute per-file hashes&lt;/b&gt;&lt;br&gt;SHA256 + entropy + ssdeep (ppdeep, pure Python)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="450" y="1500" width="300" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_extract_hash" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_extract" target="n_hash" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log extracted -->
        <mxCell id="n_log_extracted" value="log: &lt;b&gt;extracting&lt;/b&gt; &amp;rarr; &lt;b&gt;extracted&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(kind, files, duration_s)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1580" width="210" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_hash_log" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_hash" target="n_log_extracted" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="1580"/>
              <mxPoint x="500" y="1580"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== PHASE 5 — INSTALL-TIME ANALYSIS ===== -->

        <mxCell id="n_setup_target" value="&lt;b&gt;Target: setup.py&lt;/b&gt;&lt;br&gt;depth 1&amp;ndash;2 only (deeper = non-installer modules)&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;pyproject.toml / setup.cfg are declarative &amp;mdash; no code execution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="400" y="1730" width="400" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_hash_setup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_hash" target="n_setup_target" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_ast_parse" value="&lt;b&gt;AST-based analysis&lt;/b&gt;&lt;br&gt;Python ast.parse()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="510" y="1830" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_setup_ast" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_setup_target" target="n_ast_parse" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Three rules -->
        <mxCell id="n_rule_urlopen" value="&lt;b&gt;installer.urlopen_exec_chain&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;CRITICAL&lt;/font&gt; &amp;mdash; network read + exec/eval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="260" y="1920" width="260" height="50" as="geometry"/>
        </mxCell>
