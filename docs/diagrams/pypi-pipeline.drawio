      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== TITLE ===== -->
        <mxCell id="title" value="&lt;b&gt;PyPI Ecosystem Pipeline&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=20;" vertex="1" parent="1">
