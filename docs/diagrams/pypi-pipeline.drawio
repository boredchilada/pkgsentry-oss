        <mxCell id="bg_p2_label" value="&lt;b&gt;Phase 2 &amp;mdash; Watchlist&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#2d5016;" vertex="1" parent="1">
          <mxGeometry x="230" y="575" width="200" height="24" as="geometry"/>
        </mxCell>

        <!-- Phase 3 - Fetch background -->
