        <mxCell id="bg_p1_label" value="&lt;b&gt;Phase 1 &amp;mdash; Ingest&lt;/b&gt;  (async polling)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#1a3a6b;" vertex="1" parent="1">
