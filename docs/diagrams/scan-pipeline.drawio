          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_watchlist_esc" value="&lt;b&gt;Watchlist escalation&lt;/b&gt;&lt;br&gt;medium+ → suspicious&lt;br&gt;top-100 high/crit → malicious" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="510" y="1860" width="280" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_score_escalate" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_score" target="n_watchlist_esc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log persisting -->
        <mxCell id="n_log_persisting" value="log: &lt;b&gt;persisting&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(findings, hashes)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="1760" width="160" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="e_score_logp" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_score" target="n_log_persisting" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 4 — DETONATION ENQUEUE (async) ===== -->
        <mxCell id="d_detonate" value="&lt;b&gt;should_detonate()?&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;brand-new OR watchlist&lt;br&gt;OR suspicious/malicious&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="570" y="2030" width="160" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="e_esc_detonate" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_watchlist_esc" target="d_detonate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Detonate gate: No → straight to LLM check -->
        <mxCell id="n_det_skip" value="&lt;font color=&quot;#888888&quot;&gt;Don't enqueue&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="810" y="2065" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_det_no" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_detonate" target="n_det_skip" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Detonate gate: Yes → ENQUEUE only (scan does NOT wait) -->
        <mxCell id="n_enqueue" value="&lt;b&gt;Enqueue → DetonationQueue&lt;/b&gt;&lt;br&gt;priority: high = flagged/watchlist,&lt;br&gt;low = brand-new clean (best-effort)&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;static_verdict recorded; scan does NOT block&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="500" y="2190" width="300" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e_det_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_detonate" target="n_enqueue" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_enqueue_verdict" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_enqueue" target="d_verdict_mal" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== ASYNC — detonation_worker pool (runs separately from process_one) ===== -->
        <mxCell id="bg_async" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=40;dashed=1;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="1060" y="2020" width="320" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="bg_async_label" value="&lt;b&gt;Async — detonation_worker pool&lt;/b&gt;&lt;br&gt;(DETONATION_WORKERS; separate from process_one)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#6b4e00;" vertex="1" parent="1">
          <mxGeometry x="1070" y="2026" width="300" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_claim" value="&lt;b&gt;Claim job&lt;/b&gt; from DetonationQueue&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;high → low, fair across ecosystems&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1080" y="2078" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_fetch" value="&lt;b&gt;Re-fetch archive&lt;/b&gt;&lt;br&gt;by (ecosystem, name, version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1080" y="2150" width="280" height="46" as="geometry"/>
        </mxCell>
        <mxCell id="e_a_claim_fetch" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_claim" target="a_fetch" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_sandbox" value="&lt;b&gt;rootless-Docker sandbox&lt;/b&gt;&lt;br&gt;+ Tetragon eBPF traces&lt;br&gt;→ behavioral rules → dynamic findings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1080" y="2216" width="280" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_a_fetch_sandbox" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_fetch" target="a_sandbox" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_rescore" value="&lt;b&gt;Persist Detonation + TraceEvents&lt;/b&gt;&lt;br&gt;Re-score (static + dynamic)&lt;br&gt;update scan verdict&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1080" y="2296" width="280" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_a_sandbox_rescore" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_sandbox" target="a_rescore" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_alert" value="&lt;b&gt;Flipped to malicious?&lt;/b&gt;&lt;br&gt;(static_verdict was not malicious)&lt;br&gt;→ delayed Discord alert&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;send_dynamic_alert&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="1080" y="2376" width="280" height="74" as="geometry"/>
        </mxCell>
        <mxCell id="e_a_rescore_alert" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_rescore" target="a_alert" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_enqueue_async" value="async (does not block scan)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d79b00;fontColor=#d79b00;" edge="1" source="n_enqueue" target="a_claim" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 5 — LLM TRIAGE ===== -->
        <mxCell id="d_verdict_mal" value="&lt;b&gt;verdict ==&lt;br&gt;malicious?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7c5cbf;" vertex="1" parent="1">
          <mxGeometry x="585" y="2440" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_detskip_verdict" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_det_skip" target="d_verdict_mal" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="885" y="2420"/>
              <mxPoint x="650" y="2420"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Not malicious → skip LLM -->
        <mxCell id="n_llm_skip" value="&lt;font color=&quot;#888888&quot;&gt;Skip LLM triage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7c5cbf;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="810" y="2460" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_verdict_no" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_verdict_mal" target="n_llm_skip" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Malicious → LLM -->
        <mxCell id="n_llm" value="&lt;b&gt;LLM Triage&lt;/b&gt;&lt;br&gt;OpenRouter → GLM-5.1&lt;br&gt;Spotlighting anti-injection&lt;br&gt;Budget: $20/process, 1000 calls/hr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7c5cbf;" vertex="1" parent="1">
          <mxGeometry x="490" y="2560" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_verdict_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_verdict_mal" target="n_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_llm_override" value="Can override verdict&lt;br&gt;&lt;b&gt;malicious → benign&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7c5cbf;" vertex="1" parent="1">
          <mxGeometry x="530" y="2670" width="240" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_override" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_llm" target="n_llm_override" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log LLM -->
        <mxCell id="n_log_llm" value="log: &lt;b&gt;llm_triage_start&lt;/b&gt;&lt;br&gt;→ &lt;b&gt;llm_triage_done&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(cost, latency)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="2570" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_llm" target="n_log_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 6 — PERSIST ===== -->
        <mxCell id="n_persist" value="&lt;b&gt;Upsert Package / Version&lt;/b&gt;&lt;br&gt;Create Scan row, write Findings&lt;br&gt;Store FileHash rows&lt;br&gt;mark_done(row, token)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#3399ff;" vertex="1" parent="1">
          <mxGeometry x="480" y="2820" width="340" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_override_persist" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_llm_override" target="n_persist" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_llmskip_persist" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_llm_skip" target="n_persist" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="885" y="2770"/>
              <mxPoint x="650" y="2770"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="n_rulehit" value="&lt;b&gt;Bump RuleHit counters&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(separate transaction — avoids deadlocks)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#3399ff;" vertex="1" parent="1">
          <mxGeometry x="490" y="2930" width="320" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_persist_rulehit" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_persist" target="n_rulehit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log scan_done -->
        <mxCell id="n_log_done" value="log: &lt;b&gt;scan_done&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(verdict, score, n_findings, duration_s)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="2940" width="210" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_rulehit_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_rulehit" target="n_log_done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 7 — ALERT ===== -->
        <mxCell id="d_alert" value="&lt;b&gt;LLM confirmed&lt;br&gt;malicious?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="585" y="3120" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_rulehit_alert" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_rulehit" target="d_alert" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_discord" value="&lt;b&gt;Discord webhook&lt;/b&gt;&lt;br&gt;notification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="560" y="3240" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_alert_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_alert" target="n_discord" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_alert_skip" value="&lt;font color=&quot;#888888&quot;&gt;No alert&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="810" y="3140" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_alert_no" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_alert" target="n_alert_skip" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== FINALLY — CLEANUP ===== -->
        <mxCell id="n_cleanup" value="&lt;b&gt;Finally: Cleanup&lt;/b&gt;&lt;br&gt;Remove temp dirs&lt;br&gt;(extraction + archives)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="530" y="3420" width="240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_discord_cleanup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_discord" target="n_cleanup" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_alertskip_cleanup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_alert_skip" target="n_cleanup" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="870" y="3390"/>
              <mxPoint x="650" y="3390"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== END ===== -->
        <mxCell id="end" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="630" y="3520" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_cleanup_end" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_cleanup" target="end" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== ERROR PATH ===== -->
        <mxCell id="n_error" value="&lt;b&gt;ERROR PATH&lt;/b&gt;&lt;br&gt;&lt;br&gt;Any unhandled exception →&lt;br&gt;log: &lt;b&gt;pipeline_failed&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(error_type, error)&lt;/font&gt;&lt;br&gt;→ mark_failed(row, token)&lt;br&gt;→ cleanup temp dirs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#cc0000;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="1060" y="3610" width="260" height="130" as="geometry"/>
        </mxCell>
        <!-- Error path arrow from left side (any step can fail) -->
        <mxCell id="n_error_label" value="&lt;font color=&quot;#cc0000&quot;&gt;&lt;i&gt;Any step can reach&lt;br&gt;error path on exception&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="3560" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- Error → End -->
        <mxCell id="e_error_end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cc0000;dashed=1;" edge="1" source="n_error" target="end" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1190" y="3780"/>
              <mxPoint x="650" y="3780"/>
              <mxPoint x="650" y="3560"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== LEGEND ===== -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;" vertex="1" parent="1">
