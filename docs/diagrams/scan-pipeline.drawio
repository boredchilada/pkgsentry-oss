        </mxCell>
        <mxCell id="leg5t" value="Phase 3 — Score" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="72" y="235" width="130" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg6" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
