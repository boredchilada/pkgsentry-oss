          <mxGeometry x="240" y="680" width="740" height="420" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p2_label" value="&lt;b&gt;Phase 2 &amp;mdash; Watchlist&lt;/b&gt;  (weekly refresh)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#2d5016;" vertex="1" parent="1">
          <mxGeometry x="250" y="685" width="300" height="24" as="geometry"/>
        </mxCell>

        <!-- Watchlist source -->
        <mxCell id="n_wl_source" value="&lt;b&gt;Fetch top 5,000 crates&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;crates.io/api/v1/crates?sort=downloads&lt;/font&gt;&lt;br&gt;Paginated: 100/page, 1 req/s rate limit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="420" y="720" width="380" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_enqueue_wl" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_enqueue" target="n_wl_source" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Delete-and-reinsert -->
        <mxCell id="n_wl_reinsert" value="&lt;b&gt;Delete-and-reinsert&lt;/b&gt;&lt;br&gt;on weekly refresh cycle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="470" y="820" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_reinsert" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_wl_source" target="n_wl_reinsert" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- First boot seed -->
        <mxCell id="n_wl_seed" value="&lt;b&gt;First boot: seed watchlist&lt;/b&gt;&lt;br&gt;Poll &lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;crates.io/api/v1/crates/{name}&lt;/font&gt;&lt;br&gt;for newest_version of each crate&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Sequential: 1 req/s (NOT concurrent like PyPI)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="900" width="420" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_reinsert_seed" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_wl_reinsert" target="n_wl_seed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- User-Agent -->
        <mxCell id="n_wl_ua" value="User-Agent:&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;pkgsentry/${VERSION} (+${CONTACT})&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="830" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_seed_ua" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_wl_reinsert" target="n_wl_ua" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log watchlist -->
        <mxCell id="n_log_wl" value="log: &lt;b&gt;watchlist_refreshed&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(count=5000, duration_s)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1010" width="210" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_seed_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_wl_seed" target="n_log_wl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 3 — FETCH (light yellow)                                   -->
        <!-- ================================================================ -->
        <mxCell id="bg_p3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="1130" width="740" height="530" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p3_label" value="&lt;b&gt;Phase 3 &amp;mdash; Fetch&lt;/b&gt;  (async I/O)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#6b5900;" vertex="1" parent="1">
          <mxGeometry x="250" y="1135" width="260" height="24" as="geometry"/>
        </mxCell>

        <!-- Step 1: Get expected SHA -->
        <mxCell id="n_fetch_sha" value="&lt;b&gt;Step 1: GET expected SHA256&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;crates.io/api/v1/crates/{name}/{version}&lt;/font&gt;&lt;br&gt;&amp;rarr; version.checksum" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="420" y="1175" width="380" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_seed_fetch" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_wl_seed" target="n_fetch_sha" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 2: Download .crate -->
        <mxCell id="n_fetch_crate" value="&lt;b&gt;Step 2: Download .crate&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;static.crates.io/crates/{name}/{name}-{version}.crate&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Single archive only (gzipped tarball) &amp;mdash; no wheel equivalent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="1275" width="460" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_sha_crate" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_fetch_sha" target="n_fetch_crate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Rate limiting note -->
        <mxCell id="n_rate_limit" value="&lt;b&gt;Rate limiting:&lt;/b&gt;&lt;br&gt;API: semaphore + 1s sleep&lt;br&gt;CDN: 10 concurrent max" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1180" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_fetch_rate" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_fetch_sha" target="n_rate_limit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Verify SHA256 -->
        <mxCell id="n_verify_sha" value="&lt;b&gt;Verify SHA256&lt;/b&gt;&lt;br&gt;post-download against API checksum" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="470" y="1380" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_crate_verify" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_fetch_crate" target="n_verify_sha" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fetch metadata -->
        <mxCell id="n_fetch_meta" value="&lt;b&gt;Fetch crate metadata&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;crates.io/api/v1/crates/{name}&lt;/font&gt;&lt;br&gt;Normalize to match PyPI schema" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="430" y="1460" width="360" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_verify_meta" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_verify_sha" target="n_fetch_meta" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fetch OK? diamond -->
        <mxCell id="d_fetch_ok" value="&lt;b&gt;Fetch OK?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="550" y="1555" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_meta_fetchok" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_fetch_meta" target="d_fetch_ok" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fetch fail → error path -->
