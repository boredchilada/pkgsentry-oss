          <mxGeometry x="370" y="2380" width="480" height="20" as="geometry"/>
        </mxCell>

        <!-- Edge from buildrs to rules -->
        <mxCell id="e_buildrs_rules" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_buildrs_find" target="n_rules_box" parent="1">
