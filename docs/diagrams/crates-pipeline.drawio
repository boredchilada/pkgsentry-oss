          <mxGeometry x="62" y="385" width="150" height="24" as="geometry"/>
        </mxCell>

        <!-- ===== KEY DIFFERENCES CALLOUT ===== -->
        <mxCell id="diff_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f9a825;strokeWidth=2;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="990" y="80" width="370" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="diff_title" value="&lt;b&gt;Key Differences vs PyPI&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="1060" y="88" width="230" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="diff_items" value="&lt;div style=&quot;text-align:left;font-size:11px;line-height:1.6;&quot;&gt;&lt;b&gt;1.&lt;/b&gt; Single archive only (.crate) &amp;mdash; no wheel&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; No watchlist gate at ingest &amp;mdash; ALL crates enqueued&lt;br&gt;&lt;b&gt;3.&lt;/b&gt; No cursor / backfill &amp;mdash; RSS only, backfill() = 0&lt;br&gt;&lt;b&gt;4.&lt;/b&gt; build.rs analysis (7 rules, regex)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;vs setup.py (3 rules, AST)&lt;br&gt;&lt;b&gt;5.&lt;/b&gt; Sequential API (1 req/s) &amp;mdash; not concurrent&lt;br&gt;&lt;b&gt;6.&lt;/b&gt; Detonation via rootless Docker (build best-effort)&lt;br&gt;&lt;b&gt;7.&lt;/b&gt; Top 5K watchlist (vs PyPI 10K)&lt;br&gt;&lt;b&gt;8.&lt;/b&gt; XML parser (ElementTree) &amp;mdash; not regex&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1005" y="118" width="345" height="230" as="geometry"/>
        </mxCell>

        <!-- ===== START ===== -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="630" y="100" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 1 — INGEST (light blue)                                    -->
        <!-- ================================================================ -->
        <mxCell id="bg_p1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="170" width="740" height="480" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p1_label" value="&lt;b&gt;Phase 1 &amp;mdash; Ingest&lt;/b&gt;  (RSS polling, every 60s)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#1a3a6b;" vertex="1" parent="1">
          <mxGeometry x="250" y="175" width="300" height="24" as="geometry"/>
        </mxCell>

        <!-- RSS Feeds -->
        <mxCell id="n_rss_new" value="&lt;b&gt;Poll RSS: New Crates&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;static.crates.io/rss/crates.xml&lt;/font&gt;&lt;br&gt;every 60s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="340" y="220" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n_rss_update" value="&lt;b&gt;Poll RSS: Version Updates&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;static.crates.io/rss/updates.xml&lt;/font&gt;&lt;br&gt;every 60s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="630" y="220" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_start_rss1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="n_rss_new" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_start_rss2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="n_rss_update" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- XML Parser -->
        <mxCell id="n_xml_parse" value="&lt;b&gt;Parse with xml.etree.ElementTree&lt;/b&gt;&lt;br&gt;Proper XML parser (not regex)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="450" y="320" width="320" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_rss1_parse" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_rss_new" target="n_xml_parse" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_rss2_parse" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_rss_update" target="n_xml_parse" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- No backfill callout -->
        <mxCell id="n_no_backfill" value="&lt;b&gt;No cursor / serial mechanism&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;backfill() returns 0&lt;br&gt;No equivalent of PyPI XML-RPC changelog&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="400" width="240" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_parse_nobackfill" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_xml_parse" target="n_no_backfill" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ALL enqueued callout (prominent) -->
        <mxCell id="n_all_enqueued" value="&lt;b&gt;&lt;font color=&quot;#1565c0&quot; size=&quot;3&quot;&gt;ALL crates enqueued&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#1565c0&quot;&gt;No watchlist filter at ingest&lt;br&gt;(unlike PyPI which filters)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="490" y="400" width="240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_parse_enqueue" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_xml_parse" target="n_all_enqueued" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Enqueue to scan queue -->
        <mxCell id="n_enqueue" value="&lt;b&gt;Enqueue to scan_queue&lt;/b&gt;&lt;br&gt;(name, version, ecosystem=&quot;crates&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="480" y="500" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_allenq_queue" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_all_enqueued" target="n_enqueue" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log: ingest -->
        <mxCell id="n_log_ingest" value="log: &lt;b&gt;rss_polled&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(feed, new_items)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="505" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_enqueue_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_enqueue" target="n_log_ingest" parent="1">
