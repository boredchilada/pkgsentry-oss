        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 6 — UNIVERSAL ANALYSIS (purple)                            -->
        <!-- ================================================================ -->
        <mxCell id="bg_p6" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="2530" width="740" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p6_label" value="&lt;b&gt;Phase 6 &amp;mdash; Universal Analysis&lt;/b&gt;  (same as PyPI)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#4a2d6b;" vertex="1" parent="1">
          <mxGeometry x="250" y="2535" width="340" height="24" as="geometry"/>
        </mxCell>

        <!-- Universal analyzers -->
        <mxCell id="n_universal" value="&lt;b&gt;Universal Analyzers&lt;/b&gt;&lt;br&gt;analyze_imports, analyze_iocs, analyze_malware_patterns,&lt;br&gt;analyze_metadata, analyze_entropy, analyze_entropy_delta,&lt;br&gt;analyze_binary_artifacts, analyze_yara, analyze_version_diff" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="340" y="2570" width="540" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_rules_universal" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_rules_box" target="n_universal" parent="1">
