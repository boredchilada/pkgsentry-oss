        <!-- Log analyzed -->
        <mxCell id="n_log_analyzed" value="log: &lt;b&gt;analyzed&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(kind, findings, duration_s)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="2670" width="210" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_univ_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_universal" target="n_log_analyzed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 7 — NO DETONATION (gray)                                   -->
        <!-- ================================================================ -->
        <mxCell id="bg_p7" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="2760" width="740" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p7_label" value="&lt;b&gt;Phase 7 &amp;mdash; Detonation enqueue&lt;/b&gt;  (async; drained by detonation_worker)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#6b4e00;" vertex="1" parent="1">
          <mxGeometry x="250" y="2765" width="420" height="24" as="geometry"/>
        </mxCell>

        <!-- No detonation box -->
        <mxCell id="n_detonate" value="&lt;b&gt;&lt;font size=&quot;3&quot;&gt;Detonation runs async (post-score)&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;If should_detonate(): enqueue &amp;rarr; DetonationQueue. The detonation_worker pool runs &lt;font face=&quot;Courier New&quot;&gt;cargo build&lt;/font&gt; + import in a rootless-Docker sandbox (Tetragon eBPF, best-effort build), re-scores, and sends a delayed alert on a flip to malicious.&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Full worker flow: scan-pipeline.drawio&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="370" y="2800" width="480" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e_univ_nodet" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_universal" target="n_detonate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Straight-through arrow bypassing detonation -->
        <mxCell id="n_bypass_label" value="&lt;font color=&quot;#6b4e00&quot;&gt;&lt;i&gt;Crates detonation active&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="2895" width="160" height="20" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 8 — LLM TRIAGE + ALERT (light red)                        -->
        <!-- ================================================================ -->
        <mxCell id="bg_p8" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;opacity=30;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="2990" width="740" height="530" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p8_label" value="&lt;b&gt;Phase 8 &amp;mdash; LLM Triage + Alert&lt;/b&gt;  (if verdict == malicious)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="250" y="2995" width="360" height="24" as="geometry"/>
        </mxCell>

        <!-- Score + Verdict -->
        <mxCell id="n_score" value="&lt;b&gt;score_and_verdict()&lt;/b&gt;&lt;br&gt;Points: low=1, med=8, high=25, crit=60&lt;br&gt;suspicious &amp;ge; 20, malicious &amp;ge; 61" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="430" y="3030" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_nodet_score" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_detonate" target="n_score" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Verdict decision -->
        <mxCell id="d_verdict" value="&lt;b&gt;verdict ==&lt;br&gt;malicious?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="545" y="3130" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_score_verdict" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_score" target="d_verdict" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Not malicious → persist only -->
        <mxCell id="n_skip_llm" value="&lt;font color=&quot;#888888&quot;&gt;Skip LLM triage&lt;br&gt;Persist scan results&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="3145" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_verdict_no" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_verdict" target="n_skip_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Yes → LLM -->
        <mxCell id="n_llm" value="&lt;b&gt;LLM Triage&lt;/b&gt;&lt;br&gt;OpenRouter &amp;rarr; GLM-5.1&lt;br&gt;Spotlighting anti-injection&lt;br&gt;Can override: malicious &amp;rarr; benign" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="440" y="3250" width="340" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_verdict_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_verdict" target="n_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- LLM confirms? -->
        <mxCell id="d_llm_confirm" value="&lt;b&gt;LLM confirms&lt;br&gt;malicious?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="545" y="3370" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_confirm" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_llm" target="d_llm_confirm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Not confirmed → persist -->
        <mxCell id="n_llm_benign" value="&lt;font color=&quot;#888888&quot;&gt;Override to benign&lt;br&gt;Persist results&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="3385" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_no" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_llm_confirm" target="n_llm_benign" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Confirmed → Discord -->
        <mxCell id="n_discord" value="&lt;b&gt;Discord webhook&lt;/b&gt;&lt;br&gt;alert notification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="510" y="3480" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_llm_confirm" target="n_discord" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Log LLM -->
        <mxCell id="n_log_llm" value="log: &lt;b&gt;llm_triage_done&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(cost, latency, verdict)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="3265" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_llm" target="n_log_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== CLEANUP + END ===== -->
        <mxCell id="n_cleanup" value="&lt;b&gt;Persist + Cleanup&lt;/b&gt;&lt;br&gt;Upsert Package/Version, Scan, Findings, FileHash&lt;br&gt;Bump RuleHit counters&lt;br&gt;Remove temp dirs (%TEMP%/pkgsentry_crates)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="3580" width="420" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_discord_cleanup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_discord" target="n_cleanup" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_skipllm_cleanup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_skip_llm" target="n_cleanup" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="865" y="3560"/>
              <mxPoint x="610" y="3560"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_llmbenign_cleanup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_llm_benign" target="n_cleanup" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="860" y="3555"/>
              <mxPoint x="610" y="3555"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Log done -->
        <mxCell id="n_log_done" value="log: &lt;b&gt;scan_done&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(verdict, score, n_findings)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="3595" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_cleanup_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_cleanup" target="n_log_done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- END -->
        <mxCell id="end" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="590" y="3700" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_cleanup_end" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n_cleanup" target="end" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== ERROR PATH ===== -->
        <mxCell id="n_error" value="&lt;b&gt;ERROR PATH&lt;/b&gt;&lt;br&gt;&lt;br&gt;Any unhandled exception &amp;rarr;&lt;br&gt;log: &lt;b&gt;pipeline_failed&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;(error_type, error)&lt;/font&gt;&lt;br&gt;&amp;rarr; mark_failed(row, token)&lt;br&gt;&amp;rarr; cleanup temp dirs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#cc0000;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="960" y="4020" width="260" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="n_error_label" value="&lt;font color=&quot;#cc0000&quot;&gt;&lt;i&gt;Any step can reach&lt;br&gt;error path on exception&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="3970" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- Error → End -->
        <mxCell id="e_error_end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cc0000;dashed=1;" edge="1" source="n_error" target="end" parent="1">
