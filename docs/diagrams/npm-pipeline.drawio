        <!-- log done -->
        <mxCell id="n_log_done" value="log: &lt;b&gt;scan_done&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9e9e9e&quot;&gt;(verdict, score, n_findings)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;fontStyle=2;fontSize=10;fontColor=#9e9e9e;" vertex="1" parent="1">
