          <mxGeometry x="62" y="113" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="35" y="148" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg2t" value="Phase 2 &amp;mdash; Watchlist (downloads)" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
