        </mxCell>

        <!-- verdict -->
        <mxCell id="d_verdict" value="&lt;b&gt;verdict ==&lt;br&gt;malicious?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="545" y="3070" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_score_verdict" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_score" target="d_verdict" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- skip llm -->
        <mxCell id="n_skip_llm" value="&lt;font color=&quot;#9e9e9e&quot;&gt;Skip LLM triage&lt;br&gt;Persist scan results&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontStyle=2;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="780" y="3085" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_verdict_no" value="No" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;fontColor=#9e9e9e;" edge="1" source="d_verdict" target="n_skip_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- llm -->
        <mxCell id="n_llm" value="&lt;b&gt;LLM Triage&lt;/b&gt;&lt;br&gt;OpenRouter &amp;rarr; GLM-5.1 (cost-gated)&lt;br&gt;Spotlighting anti-injection&lt;br&gt;Can override: malicious &amp;rarr; benign" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="440" y="3190" width="340" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_verdict_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;fontColor=#757575;" edge="1" source="d_verdict" target="n_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- llm confirm -->
        <mxCell id="d_llm_confirm" value="&lt;b&gt;LLM confirms&lt;br&gt;malicious?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="545" y="3310" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_confirm" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_llm" target="d_llm_confirm" parent="1">
