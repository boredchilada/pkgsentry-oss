        <mxCell id="leg4t" value="Phase 4 &amp;mdash; Extract + Hash" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="62" y="203" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="35" y="238" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg5t" value="Phase 5 &amp;mdash; Install-time (scripts)" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="62" y="233" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg6" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="35" y="268" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg6t" value="Phase 6 &amp;mdash; Universal analysis" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="62" y="263" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg7" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="35" y="298" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg7t" value="Phase 7 &amp;mdash; Detonation (npm install)" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="62" y="293" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg8" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="35" y="328" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg8t" value="Phase 8 &amp;mdash; Score + LLM + Alert" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="62" y="323" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg9" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="35" y="358" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg9t" value="Log events" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="62" y="353" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg10" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="35" y="386" width="20" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="leg10t" value="Decision" style="text;html=1;align=left;fontSize=10;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="62" y="383" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="leg_note" value="&lt;i&gt;Dashed grey = unbuilt&lt;/i&gt;" style="text;html=1;align=center;fontSize=9;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="35" y="415" width="190" height="20" as="geometry"/>
        </mxCell>

        <!-- ===== NPM SPECIFICS CALLOUT ===== -->
        <mxCell id="diff_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;strokeWidth=2;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="1000" y="92" width="380" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="diff_title" value="&lt;b&gt;npm specifics (planned design)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="1060" y="100" width="260" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="diff_items" value="&lt;div style=&quot;text-align:left;font-size:11px;line-height:1.6;color:#757575;&quot;&gt;&lt;b&gt;1.&lt;/b&gt; Ingest via CouchDB &lt;font face=&quot;Courier New&quot;&gt;_changes&lt;/font&gt; feed&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;cursor (seq) &amp;mdash; not RSS&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; &lt;font face=&quot;Courier New&quot;&gt;since&lt;/font&gt; seq NOT guaranteed monotonic&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;(reset on CouchDB upgrades)&lt;br&gt;&lt;b&gt;3.&lt;/b&gt; Single .tgz archive (gzip tar, &lt;font face=&quot;Courier New&quot;&gt;package/&lt;/font&gt;)&lt;br&gt;&lt;b&gt;4.&lt;/b&gt; Integrity = SRI &lt;font face=&quot;Courier New&quot;&gt;sha512&lt;/font&gt; from dist (+shasum)&lt;br&gt;&lt;b&gt;5.&lt;/b&gt; Scoped names &lt;font face=&quot;Courier New&quot;&gt;@scope/name&lt;/font&gt; in URL path&lt;br&gt;&lt;b&gt;6.&lt;/b&gt; Primary RCE = package.json lifecycle&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;scripts (preinstall/install/postinstall)&lt;br&gt;&lt;b&gt;7.&lt;/b&gt; Detonation runs &lt;font face=&quot;Courier New&quot;&gt;npm install&lt;/font&gt; with&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;scripts ENABLED in rootless Docker&lt;br&gt;&lt;b&gt;8.&lt;/b&gt; Watchlist from npm downloads API&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1015" y="130" width="350" height="270" as="geometry"/>
        </mxCell>

        <!-- ===== START ===== -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9e9e9e;strokeColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="630" y="170" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 1 - INGEST                                                 -->
        <!-- ================================================================ -->
        <mxCell id="bg_p1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="240" width="740" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p1_label" value="&lt;b&gt;Phase 1 &amp;mdash; Ingest&lt;/b&gt;  (CouchDB _changes feed, cursor-based)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="250" y="245" width="420" height="24" as="geometry"/>
        </mxCell>

        <!-- _changes feed -->
        <mxCell id="n_changes" value="&lt;b&gt;Poll _changes feed&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;replicate.npmjs.com/_changes?since={seq}&lt;/font&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;&amp;feed=continuous (or longpoll)&lt;/font&gt;&lt;br&gt;Each row: {seq, id (pkg name), changes}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="380" y="290" width="460" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_start_changes" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="start" target="n_changes" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- cursor -->
        <mxCell id="n_cursor" value="&lt;b&gt;Track seq in ScanCursor&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9e9e9e&quot;&gt;seq NOT guaranteed monotonic&lt;br&gt;(reset on CouchDB upgrades) &amp;mdash; treat as opaque&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;fontStyle=2;fontSize=10;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="260" y="300" width="240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_changes_cursor" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_changes" target="n_cursor" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- fetch metadata -->
        <mxCell id="n_meta" value="&lt;b&gt;Fetch package metadata&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;GET registry.npmjs.org/{pkg}&lt;/font&gt;&lt;br&gt;&amp;rarr; dist-tags, versions{}, time{}, maintainers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="420" y="400" width="380" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_changes_meta" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_changes" target="n_meta" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Ingest gate decision -->
        <mxCell id="d_gate" value="&lt;b&gt;Ingest gate:&lt;br&gt;watchlist OR&lt;br&gt;brand-new pkg?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="540" y="500" width="140" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_meta_gate" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_meta" target="d_gate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- skip -->
        <mxCell id="n_skip_ingest" value="&lt;font color=&quot;#9e9e9e&quot;&gt;Existing non-watchlist&lt;br&gt;version update &amp;rarr; SKIP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;fontStyle=2;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="780" y="515" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_gate_skip" value="No" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;fontColor=#9e9e9e;" edge="1" source="d_gate" target="n_skip_ingest" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- enqueue -->
        <mxCell id="n_enqueue" value="&lt;b&gt;Enqueue to scan_queue&lt;/b&gt;&lt;br&gt;(name, version, ecosystem=&quot;npm&quot;)&lt;br&gt;watchlist &amp;rarr; high  |  brand-new &amp;rarr; normal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="450" y="620" width="320" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_gate_enqueue" value="Yes" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;fontColor=#757575;" edge="1" source="d_gate" target="n_enqueue" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- log ingest -->
        <mxCell id="n_log_ingest" value="log: &lt;b&gt;changes_polled&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9e9e9e&quot;&gt;(last_seq, new_items)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;fontStyle=2;fontSize=10;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="800" y="630" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_enqueue_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_enqueue" target="n_log_ingest" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 2 - WATCHLIST                                              -->
        <!-- ================================================================ -->
        <mxCell id="bg_p2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="770" width="740" height="270" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p2_label" value="&lt;b&gt;Phase 2 &amp;mdash; Watchlist&lt;/b&gt;  (top packages by downloads, weekly refresh)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="250" y="775" width="420" height="24" as="geometry"/>
        </mxCell>

        <!-- watchlist source -->
        <mxCell id="n_wl_source" value="&lt;b&gt;Build top ~10K npm watchlist&lt;/b&gt;&lt;br&gt;Source: top-packages list + npm downloads API&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;api.npmjs.org/downloads/point/last-week/{pkg}&lt;/font&gt;&lt;br&gt;(bulk: comma-separated, scoped pkgs excluded from bulk)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="400" y="810" width="420" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_enqueue_wl" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_enqueue" target="n_wl_source" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- delete-reinsert -->
        <mxCell id="n_wl_reinsert" value="&lt;b&gt;Delete-and-reinsert&lt;/b&gt;&lt;br&gt;on weekly refresh; matched against _changes ids&lt;br&gt;(protects high-blast-radius packages)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="430" y="920" width="360" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_reinsert" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_wl_source" target="n_wl_reinsert" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- UA note -->
        <mxCell id="n_wl_ua" value="User-Agent:&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;pkgsentry/${VERSION} (+${CONTACT})&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;fontStyle=2;fontSize=10;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="260" y="925" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_ua" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_wl_reinsert" target="n_wl_ua" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- log watchlist -->
        <mxCell id="n_log_wl" value="log: &lt;b&gt;watchlist_refreshed&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9e9e9e&quot;&gt;(count=10000, duration_s)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;fontStyle=2;fontSize=10;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="800" y="930" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_wl_reinsert" target="n_log_wl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 3 - FETCH                                                  -->
        <!-- ================================================================ -->
        <mxCell id="bg_p3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="1070" width="740" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p3_label" value="&lt;b&gt;Phase 3 &amp;mdash; Fetch&lt;/b&gt;  (async I/O, integrity verify)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="250" y="1075" width="360" height="24" as="geometry"/>
        </mxCell>

        <!-- step 1: integrity from dist -->
        <mxCell id="n_fetch_int" value="&lt;b&gt;Step 1: read dist.integrity + dist.shasum&lt;/b&gt;&lt;br&gt;from version metadata (versions[v].dist)&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;integrity = sha512-&amp;lt;base64&amp;gt; (SRI), shasum = sha1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="400" y="1115" width="420" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_wl_int" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_wl_reinsert" target="n_fetch_int" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- step 2: download tgz -->
        <mxCell id="n_fetch_tgz" value="&lt;b&gt;Step 2: download .tgz&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;registry.npmjs.org/{pkg}/-/{pkg}-{version}.tgz&lt;/font&gt;&lt;br&gt;scoped: &lt;font face=&quot;Courier New&quot; size=&quot;1&quot;&gt;/@{scope}/{name}/-/{name}-{version}.tgz&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9e9e9e&quot;&gt;gzip tarball, single archive (no wheel equivalent)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="380" y="1215" width="460" height="80" as="geometry"/>
        </mxCell>
