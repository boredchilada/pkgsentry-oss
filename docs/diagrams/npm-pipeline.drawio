        </mxCell>

        <!-- benign override -->
        <mxCell id="n_llm_benign" value="&lt;font color=&quot;#9e9e9e&quot;&gt;Override to benign&lt;br&gt;Persist results&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontStyle=2;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="780" y="3325" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_no" value="No" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;fontColor=#9e9e9e;" edge="1" source="d_llm_confirm" target="n_llm_benign" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- discord -->
        <mxCell id="n_discord" value="&lt;b&gt;Discord webhook&lt;/b&gt;&lt;br&gt;alert notification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="510" y="3420" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;fontColor=#757575;" edge="1" source="d_llm_confirm" target="n_discord" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- log llm -->
        <mxCell id="n_log_llm" value="log: &lt;b&gt;llm_triage_done&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9e9e9e&quot;&gt;(cost, latency, verdict)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;dashed=1;dashPattern=8 4;fontStyle=2;fontSize=10;fontColor=#9e9e9e;" vertex="1" parent="1">
          <mxGeometry x="280" y="3205" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_llm_log" style="dashed=1;strokeColor=#CCCCCC;" edge="1" source="n_llm" target="n_log_llm" parent="1">
