        <mxCell id="bg_p8" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="240" y="2930" width="740" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="bg_p8_label" value="&lt;b&gt;Phase 8 &amp;mdash; Score + LLM Triage + Alert&lt;/b&gt;  (if verdict == malicious)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="250" y="2935" width="430" height="24" as="geometry"/>
        </mxCell>

        <!-- score -->
        <mxCell id="n_score" value="&lt;b&gt;score_and_verdict()&lt;/b&gt;&lt;br&gt;Points: low=1, med=8, high=25, crit=60&lt;br&gt;suspicious &amp;ge; 20, malicious &amp;ge; 61 (shared)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="430" y="2970" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_rescore_score" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#bdbdbd;" edge="1" source="n_rescore" target="n_score" parent="1">
