        </mxCell>

        <!-- cleanup -->
        <mxCell id="n_cleanup" value="&lt;b&gt;Persist + Cleanup&lt;/b&gt;&lt;br&gt;Upsert Package/Version, Scan, Findings, FileHash&lt;br&gt;Bump RuleHit counters&lt;br&gt;Remove temp dirs (pkgsentry_npm)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;dashed=1;dashPattern=8 4;fontColor=#757575;" vertex="1" parent="1">
          <mxGeometry x="400" y="3520" width="420" height="80" as="geometry"/>
