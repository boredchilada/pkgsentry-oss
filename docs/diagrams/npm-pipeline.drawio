        <!-- ===== ERROR PATH ===== -->
        <mxCell id="n_error" value="&lt;b&gt;ERROR PATH&lt;/b&gt;&lt;br&gt;&lt;br&gt;Any unhandled exception &amp;rarr;&lt;br&gt;log: &lt;b&gt;pipeline_failed&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9e9e9e&quot;&gt;(error_type, error)&lt;/font&gt;&lt;br&gt;&amp;rarr; mark_failed(row, token)&lt;br&gt;&amp;rarr; cleanup temp dirs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bdbdbd;fontColor=#9e9e9e;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
