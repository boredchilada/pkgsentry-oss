        <mxCell id="trans-2-3" value="&lt;b&gt;automatic&lt;/b&gt;&lt;br&gt;&lt;i&gt;workers start&lt;br&gt;before boot&lt;/i&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="phase2-box" target="phase3-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
