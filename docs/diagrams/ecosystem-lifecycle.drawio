          <mxGeometry x="60" y="530" width="30" height="25" as="geometry" />
        </mxCell>
        <mxCell id="state-pypi" value="&lt;b&gt;PyPI:&lt;/b&gt; Phase 4 (incremental) — 10K watchlist, ~10K baseline done, 2.1M file hashes" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
