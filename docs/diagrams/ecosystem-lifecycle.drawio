        <mxCell id="env-title" value="&lt;b&gt;Environment Controls&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#666;" vertex="1" parent="1">
