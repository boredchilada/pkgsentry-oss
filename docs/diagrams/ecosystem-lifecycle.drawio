        <mxCell id="trans-3-4" value="&lt;b&gt;automatic&lt;/b&gt;&lt;br&gt;&lt;i&gt;once file_hash&lt;br&gt;rows exist&lt;/i&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="phase3-box" target="phase4-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
