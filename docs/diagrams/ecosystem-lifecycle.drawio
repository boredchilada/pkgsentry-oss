          <mxGeometry x="60" y="565" width="30" height="25" as="geometry" />
        </mxCell>
        <mxCell id="state-crates" value="&lt;b&gt;Crates.io:&lt;/b&gt; Phase 2→3 (baseline in progress) — 5K watchlist, ~466 pending" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="565" width="620" height="25" as="geometry" />
        </mxCell>

