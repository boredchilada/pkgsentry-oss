          <mxGeometry x="40" y="490" width="700" height="120" as="geometry" />
        </mxCell>
        <mxCell id="state-title" value="&lt;b&gt;Current State (2026-05-23)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="55" y="495" width="300" height="25" as="geometry" />
