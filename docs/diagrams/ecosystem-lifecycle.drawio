        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="env-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;arcSize=6;dashed=1;dashPattern=5 3;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="490" width="530" height="120" as="geometry" />
