<mxfile host="app.diagrams.net" agent="pkgsentry" version="26.0.0">
  <diagram id="code-diff-flow" name="Code-Diff Scanning Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Code-Diff Scanning Flow" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Step 1: Package arrives -->
        <mxCell id="step1" value="&lt;b&gt;Package Arrives&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;ecosystem/name==version&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 1→2 -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 2: Download + extract -->
        <mxCell id="step2" value="&lt;b&gt;Download + Extract Archives&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;sdist, wheel, crate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="580" y="180" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 2→3 -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Compute per-file hashes -->
        <mxCell id="step3" value="&lt;b&gt;For Each Archive: Compute Per-File Hashes&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="545" y="280" width="310" height="50" as="geometry" />
        </mxCell>

        <!-- Sub-steps of step 3 (grouped) -->
        <mxCell id="grp3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b3b3b3;strokeWidth=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="350" width="520" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s3a" value="Walk all files in&lt;br&gt;extracted archive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="455" y="365" width="140" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s3b" value="Normalize paths&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;strip top-level dir for&lt;br&gt;sdist / crate archives&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="365" width="160" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s3c" value="Compute:&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SHA256, Shannon entropy,&lt;br&gt;ssdeep fuzzy hash&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="805" y="365" width="140" height="45" as="geometry" />
        </mxCell>
        <mxCell id="e3a" style="edgeStyle=orthogonalEdgeStyle;rounded=1;entryX=0;entryY=0.5;" edge="1" source="s3a" target="s3b" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;entryX=0;entryY=0.5;" edge="1" source="s3b" target="s3c" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Note on path normalization -->
        <mxCell id="note3" value="&lt;font style=&quot;font-size:10px&quot;&gt;e.g. &lt;code&gt;fastapi-0.115.0/fastapi/main.py&lt;/code&gt;&lt;br&gt;→ &lt;code&gt;fastapi/main.py&lt;/code&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="600" y="420" width="280" height="35" as="geometry" />
        </mxCell>

        <!-- Arrow 3→4 -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="grp3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: Query DB for previous hashes -->
        <mxCell id="step4" value="&lt;b&gt;Query DB&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;code&gt;_get_prev_scan_hashes()&lt;/code&gt;&lt;br&gt;Get FileHash rows from most recent&lt;br&gt;scan of any PREVIOUS version&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="500" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Arrow 4→decision -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="step4" target="decision" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision: Previous hashes exist? -->
        <mxCell id="decision" value="Previous&lt;br&gt;hashes exist?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="630" y="630" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- NO branch: First scan / baseline -->
        <mxCell id="eNo" value="&lt;b&gt;NO&lt;/b&gt;&lt;br&gt;(first scan)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontStyle=0;fontSize=11;" edge="1" source="decision" target="branchNo" parent="1">
          <mxGeometry x="-0.3" y="15" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="branchNo" value="&lt;b&gt;Analyze ALL Files&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;This is the baseline&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="280" y="655" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- YES branch -->
        <mxCell id="eYes" value="&lt;b&gt;YES&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=11;" edge="1" source="decision" target="compare" parent="1">
          <mxGeometry x="-0.3" y="-15" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="compare" value="&lt;b&gt;Compare SHA256&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;current vs previous per&lt;br&gt;normalized path&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="880" y="650" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Compare → decision2 -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="compare" target="decision2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision 2: Any changes? -->
        <mxCell id="decision2" value="Changed&lt;br&gt;files found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="760" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- NO changes -->
        <mxCell id="eNoCh" value="&lt;b&gt;NO&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=11;" edge="1" source="decision2" target="skipAnalysis" parent="1">
          <mxGeometry x="-0.3" y="15" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="skipAnalysis" value="&lt;b&gt;Skip Analysis&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;log &lt;code&gt;no_code_changes&lt;/code&gt;&lt;br&gt;for this archive&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;arcSize=30;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1160" y="780" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- YES changes -->
        <mxCell id="eYesCh" value="&lt;b&gt;YES&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=11;" edge="1" source="decision2" target="analyzeChanged" parent="1">
          <mxGeometry x="-0.3" y="-15" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="analyzeChanged" value="&lt;b&gt;Analyze ONLY Changed Files&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;log &lt;code&gt;code_diff&lt;/code&gt; with&lt;br&gt;changed/total counts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="680" y="780" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- All paths converge to Store Hashes -->
        <mxCell id="eStore1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="branchNo" target="storeHashes" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="950" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="eStore2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="analyzeChanged" target="storeHashes" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="790" y="870" />
              <mxPoint x="700" y="870" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="eStore3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="skipAnalysis" target="storeHashes" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1260" y="950" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 6: Store hashes -->
        <mxCell id="storeHashes" value="&lt;b&gt;Store All Current File Hashes&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Insert into &lt;code&gt;file_hash&lt;/code&gt; table&lt;br&gt;(for next version's diff)&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="580" y="920" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- FileHash table schema box -->
        <mxCell id="schema" value="&lt;b&gt;FileHash Table&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:11px&quot;&gt;scan_id&lt;br&gt;archive_kind&lt;br&gt;file_path &lt;i&gt;(normalized)&lt;/i&gt;&lt;br&gt;sha256&lt;br&gt;ssdeep&lt;br&gt;entropy&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="130" y="350" width="170" height="140" as="geometry" />
        </mxCell>

        <!-- Performance note -->
        <mxCell id="perfNote" value="&lt;b&gt;Performance Example&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:11px&quot;&gt;fastapi baseline: ~2.1M file hashes&lt;br&gt;New version: skips 96% unchanged files&lt;br&gt;Only analyzes new + modified files&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="130" y="780" width="260" height="90" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
